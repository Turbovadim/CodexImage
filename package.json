{
  "name": "codeximage",
  "version": "2.0.0",
  "license": "MIT",
  "main": "electron/main.mjs",
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "svelte-check": "^4.7.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  },
  "build": {
    "appId": "com.yolki.codeximage",
    "productName": "CodexImage",
    "asar": false,
    "directories": {
      "output": "release",
      "buildResources": "buildResources"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "dist-electron/**/*",
      "!node_modules/**"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "icon": "buildResources/icon.icns"
    }
  },
  "description": "Local image-generation studio: node-canvas UI on top of Codex CLI (uses your ChatGPT subscription)",
  "engines": {
    "node": ">=22.7"
  },
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"node --watch server.ts\" \"vite\"",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=esm --outfile=dist-electron/server.mjs",
    "app": "npm run build && npm run build:server && electron .",
    "app:dist": "npm run build && npm run build:server && electron-builder --mac dir",
    "app:install": "npm run app:dist && (osascript -e 'tell application \"CodexImage\" to quit' >/dev/null 2>&1; sleep 1; true) && rm -rf /Applications/CodexImage.app && cp -R release/mac-arm64/CodexImage.app /Applications/ && open /Applications/CodexImage.app",
    "start": "node server.ts",
    "test": "node --test src/*.test.ts",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json"
  },
  "type": "module",
  "dependencies": {
    "@xyflow/svelte": "^1.6.2",
    "svelte": "^5.56.4"
  }
}
